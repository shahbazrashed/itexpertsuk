<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>IT Experts UK Ltd | Azure Cloud Architecture &amp; Transformation</title>
  <meta name="description" content="Senior Azure Cloud Architect with 25+ years experience. Expert in cloud transformation, governance, and DevOps for enterprise and public sector organisations across the UK." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:       #0b1929;
      --navy-mid:   #122038;
      --navy-light: #1a3050;
      --azure:      #0078d4;
      --azure-light:#50e6ff;
      --azure-glow: rgba(0,120,212,0.15);
      --white:      #ffffff;
      --off-white:  #f4f7fb;
      --grey-100:   #e8edf4;
      --grey-400:   #8a9bb5;
      --grey-600:   #4a5568;
      --text:       #1a2740;
      --transition: 0.25s ease;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      color: var(--text);
      background: var(--white);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── UTILITIES ─────────────────────────────────── */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .section    { padding: 96px 0; }
    .section--grey { background: var(--off-white); }
    .section--dark { background: var(--navy); color: var(--white); }

    .tag {
      display: inline-block;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--azure);
      background: var(--azure-glow);
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 16px;
    }
    .section--dark .tag { background: rgba(80,230,255,0.12); color: var(--azure-light); }

    h1,h2,h3,h4 { line-height: 1.2; font-weight: 800; }

    .section-title {
      font-size: clamp(32px, 4vw, 46px);
      color: var(--navy);
      margin-bottom: 16px;
    }
    .section--dark .section-title { color: var(--white); }

    .section-sub {
      font-size: 18px;
      color: var(--grey-600);
      max-width: 600px;
      line-height: 1.7;
    }
    .section--dark .section-sub { color: rgba(255,255,255,0.65); }

    .section-header { margin-bottom: 60px; }
    .section-header--center { text-align: center; }
    .section-header--center .section-sub { margin: 0 auto; }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      border-radius: 6px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      border: none;
      transition: all var(--transition);
    }
    .btn-primary {
      background: var(--azure);
      color: var(--white);
    }
    .btn-primary:hover { background: #006cbf; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,120,212,0.3); }

    .btn-outline {
      background: transparent;
      color: var(--white);
      border: 2px solid rgba(255,255,255,0.4);
    }
    .btn-outline:hover { border-color: var(--white); background: rgba(255,255,255,0.08); }

    .btn-dark {
      background: var(--white);
      color: var(--azure);
    }
    .btn-dark:hover { background: var(--off-white); transform: translateY(-1px); }

    /* ── NAVBAR ─────────────────────────────────────── */
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      background: rgba(11, 25, 41, 0.96);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      transition: all var(--transition);
    }
    .navbar__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }
    .navbar__logo {
      display: flex;
      align-items: center;
      text-decoration: none;
    }
    .navbar__logo img {
      height: 40px;
      width: auto;
      background: white;
      padding: 5px 10px;
      border-radius: 7px;
      display: block;
      transition: opacity var(--transition);
    }
    .navbar__logo:hover img { opacity: 0.9; }
    .footer__logo img {
      height: 44px;
      width: auto;
      background: white;
      padding: 5px 10px;
      border-radius: 7px;
      display: block;
      opacity: 0.9;
    }
    .navbar__nav {
      display: flex;
      align-items: center;
      gap: 36px;
      list-style: none;
    }
    .navbar__nav a {
      color: rgba(255,255,255,0.75);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: color var(--transition);
    }
    .navbar__nav a:hover { color: var(--white); }
    .navbar__cta { display: flex; gap: 12px; align-items: center; }
    .navbar__cta .btn { padding: 10px 20px; font-size: 14px; }

    /* ── HERO ───────────────────────────────────────── */
    .hero {
      background: var(--navy);
      min-height: 100vh;
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding-top: 72px;
    }
    .hero__bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 70% 50%, rgba(0,120,212,0.18) 0%, transparent 60%),
        radial-gradient(ellipse 40% 40% at 20% 80%, rgba(80,230,255,0.08) 0%, transparent 50%);
    }
    .hero__grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .hero__content {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      padding: 80px 0;
    }
    .hero__left {}
    .hero__badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0,120,212,0.15);
      border: 1px solid rgba(0,120,212,0.3);
      color: var(--azure-light);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 8px 16px;
      border-radius: 100px;
      margin-bottom: 28px;
    }
    .hero__badge::before {
      content: '';
      width: 6px; height: 6px;
      background: var(--azure-light);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.8); }
    }
    .hero__title {
      font-size: clamp(40px, 5vw, 64px);
      font-weight: 900;
      color: var(--white);
      line-height: 1.08;
      letter-spacing: -1px;
      margin-bottom: 24px;
    }
    .hero__title span {
      background: linear-gradient(135deg, var(--azure), var(--azure-light));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero__sub {
      font-size: 18px;
      color: rgba(255,255,255,0.65);
      line-height: 1.75;
      margin-bottom: 40px;
      max-width: 520px;
    }
    .hero__actions { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
    .hero__right { display: flex; justify-content: flex-end; }

    /* Hero card */
    .hero__card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      padding: 40px;
      width: 100%;
      max-width: 400px;
      backdrop-filter: blur(10px);
    }
    .hero__card-avatar {
      width: 80px; height: 80px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--azure), var(--azure-light));
      display: flex; align-items: center; justify-content: center;
      font-size: 32px; font-weight: 800; color: white;
      margin-bottom: 20px;
    }
    .hero__card-name {
      font-size: 20px; font-weight: 800; color: var(--white); margin-bottom: 4px;
    }
    .hero__card-role {
      font-size: 13px; color: var(--azure-light); font-weight: 500; margin-bottom: 20px;
    }
    .hero__card-divider {
      height: 1px; background: rgba(255,255,255,0.1); margin: 20px 0;
    }
    .hero__cert-list { display: flex; flex-direction: column; gap: 10px; }
    .hero__cert {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: rgba(255,255,255,0.75);
      font-weight: 500;
    }
    .hero__cert-icon {
      width: 28px; height: 28px;
      background: rgba(0,120,212,0.2);
      border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
    }
    .hero__card-footer {
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,0.08);
      display: flex; gap: 20px;
    }
    .hero__stat { text-align: center; }
    .hero__stat-num { font-size: 24px; font-weight: 900; color: var(--white); }
    .hero__stat-label { font-size: 11px; color: var(--grey-400); font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; }

    /* ── LOGOS / PARTNER STRIP ──────────────────────── */
    .partners {
      background: var(--off-white);
      padding: 40px 0;
      border-top: 1px solid var(--grey-100);
      border-bottom: 1px solid var(--grey-100);
    }
    .partners__inner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 60px;
      flex-wrap: wrap;
    }
    .partners__label {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--grey-400);
      white-space: nowrap;
    }
    .partners__logos { display: flex; align-items: center; gap: 48px; flex-wrap: wrap; justify-content: center; }
    .partners__logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      opacity: 0.55;
      transition: opacity var(--transition);
    }
    .partners__logo:hover { opacity: 1; }
    .partners__logo-img {
      height: 28px;
      object-fit: contain;
      filter: grayscale(100%);
    }
    .partner-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      background: white;
      border: 1px solid var(--grey-100);
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      color: var(--grey-600);
    }
    .partner-badge span { color: var(--azure); }

    /* ── SERVICES ───────────────────────────────────── */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 28px;
    }
    .service-card {
      background: var(--white);
      border: 1px solid var(--grey-100);
      border-radius: 12px;
      padding: 36px;
      transition: all var(--transition);
      position: relative;
      overflow: hidden;
    }
    .service-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--azure), var(--azure-light));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.35s ease;
    }
    .service-card:hover { border-color: var(--azure); box-shadow: 0 12px 40px rgba(0,120,212,0.1); transform: translateY(-4px); }
    .service-card:hover::after { transform: scaleX(1); }

    .service-icon {
      width: 52px; height: 52px;
      background: linear-gradient(135deg, rgba(0,120,212,0.1), rgba(80,230,255,0.08));
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 24px;
      font-size: 24px;
    }
    .service-card h3 {
      font-size: 20px; font-weight: 700; color: var(--navy); margin-bottom: 12px;
    }
    .service-card p {
      font-size: 15px; color: var(--grey-600); line-height: 1.7; margin-bottom: 20px;
    }
    .service-link {
      font-size: 14px; font-weight: 600; color: var(--azure); text-decoration: none;
      display: inline-flex; align-items: center; gap: 4px;
      transition: gap var(--transition);
    }
    .service-link:hover { gap: 8px; }

    /* ── STATS ──────────────────────────────────────── */
    .stats { background: var(--navy); padding: 72px 0; }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
    .stat-item {
      text-align: center;
      padding: 32px;
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-size: clamp(40px, 5vw, 56px);
      font-weight: 900;
      background: linear-gradient(135deg, var(--azure), var(--azure-light));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1;
      margin-bottom: 8px;
    }
    .stat-label {
      font-size: 14px;
      color: rgba(255,255,255,0.55);
      font-weight: 500;
    }

    /* ── WHY CHOOSE ─────────────────────────────────── */
    .why-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .why-image {
      background: linear-gradient(135deg, var(--navy), var(--navy-light));
      border-radius: 16px;
      padding: 48px;
      display: grid;
      gap: 16px;
    }
    .why-feature {
      display: flex;
      gap: 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 20px;
    }
    .why-feature-icon {
      width: 40px; height: 40px; min-width: 40px;
      background: rgba(0,120,212,0.2);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
    }
    .why-feature-text h4 { font-size: 15px; color: var(--white); font-weight: 700; margin-bottom: 4px; }
    .why-feature-text p { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5; }

    .why-points { display: flex; flex-direction: column; gap: 24px; }
    .why-point {
      display: flex;
      gap: 16px;
      align-items: flex-start;
    }
    .why-point-num {
      width: 36px; height: 36px; min-width: 36px;
      background: var(--azure);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; font-weight: 800; color: white;
    }
    .why-point-text h4 { font-size: 17px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
    .why-point-text p { font-size: 15px; color: var(--grey-600); line-height: 1.65; }

    /* ── ABOUT ──────────────────────────────────────── */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 80px;
      align-items: start;
    }
    .about-photo {
      position: relative;
    }
    .about-photo__img {
      width: 100%;
      aspect-ratio: 4/5;
      background: linear-gradient(135deg, var(--navy-light), var(--navy));
      border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      font-size: 72px; font-weight: 900;
      color: rgba(255,255,255,0.1);
    }
    .about-photo__badge {
      position: absolute;
      bottom: -20px; right: -20px;
      background: var(--azure);
      color: white;
      border-radius: 12px;
      padding: 20px;
      text-align: center;
    }
    .about-photo__badge-num { font-size: 32px; font-weight: 900; line-height: 1; }
    .about-photo__badge-text { font-size: 12px; font-weight: 600; opacity: 0.85; letter-spacing: 0.04em; }
    .about-content { padding-top: 8px; }
    .about-content p { font-size: 16px; color: var(--grey-600); line-height: 1.8; margin-bottom: 20px; }
    .about-certs {
      margin-top: 32px;
      display: flex; flex-wrap: wrap; gap: 10px;
    }
    /* ── CERT BADGES ── */
    .hero__cert { display: flex; gap: 12px; align-items: center; }
    .cert-hex { width: 36px; min-width: 36px; height: 36px; }
    .cert-hex svg { width: 100%; height: 100%; }
    .hero__cert-text { display: flex; flex-direction: column; gap: 2px; }
    .cert-level-tag {
      font-size: 9px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.1em; padding: 1px 6px; border-radius: 3px;
      display: inline-block; width: fit-content;
    }
    .cert-level-tag--expert  { background: rgba(92,45,145,0.25); color: #c8a0f0; }
    .cert-level-tag--associate { background: rgba(0,120,212,0.2); color: #80c8ff; }
    .cert-level-tag--specialty { background: rgba(0,183,195,0.2); color: #60dde5; }
    .cert-level-tag--other   { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); }
    .hero__cert-name { font-size: 12px; color: rgba(255,255,255,0.82); font-weight: 500; line-height: 1.3; }

    /* About section cert pills */
    .cert-pill {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 7px 14px 7px 7px;
      background: var(--off-white);
      border: 1px solid var(--grey-100);
      border-radius: 100px;
      font-size: 13px; font-weight: 600; color: var(--navy);
    }
    .cert-pill-badge { width: 22px; height: 22px; flex-shrink: 0; }
    .cert-pill-badge svg { width: 100%; height: 100%; }

    /* ── CASE STUDIES ───────────────────────────────── */
    .case-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 28px;
    }
    .case-card {
      background: var(--white);
      border: 1px solid var(--grey-100);
      border-radius: 12px;
      overflow: hidden;
      transition: all var(--transition);
    }
    .case-card:hover { box-shadow: 0 16px 48px rgba(0,0,0,0.1); transform: translateY(-4px); }
    .case-card__header {
      padding: 32px;
      background: var(--navy);
      position: relative;
    }
    .case-card__sector {
      font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--azure-light); margin-bottom: 12px;
    }
    .case-card__title {
      font-size: 20px; font-weight: 800; color: var(--white); line-height: 1.3;
    }
    .case-card__body { padding: 32px; }
    .case-card__challenge {
      font-size: 14px; font-weight: 600; color: var(--grey-400);
      text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px;
    }
    .case-card__text {
      font-size: 15px; color: var(--grey-600); line-height: 1.7; margin-bottom: 24px;
    }
    .case-card__outcomes { display: flex; flex-wrap: wrap; gap: 8px; }
    .outcome-tag {
      padding: 5px 12px;
      background: rgba(0,120,212,0.07);
      color: var(--azure);
      border-radius: 100px;
      font-size: 12px;
      font-weight: 600;
    }

    /* ── APPROACH ───────────────────────────────────── */
    .approach-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      background: var(--white);
      border: 1px solid var(--grey-100);
      border-radius: 16px;
      overflow: hidden;
    }
    .approach-step {
      padding: 40px 32px;
      border-right: 1px solid var(--grey-100);
      position: relative;
    }
    .approach-step:last-child { border-right: none; }
    .approach-step__num {
      font-size: 48px; font-weight: 900;
      color: var(--grey-100);
      line-height: 1;
      margin-bottom: 16px;
      font-variant-numeric: tabular-nums;
    }
    .approach-step h3 { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: 10px; }
    .approach-step p { font-size: 14px; color: var(--grey-600); line-height: 1.65; }

    /* ── CTA BANNER ─────────────────────────────────── */
    .cta-banner {
      background: linear-gradient(135deg, var(--azure) 0%, #005fa3 100%);
      padding: 80px 0;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-banner::before {
      content: '';
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 50% 80% at 0% 50%, rgba(255,255,255,0.08) 0%, transparent 60%),
        radial-gradient(ellipse 50% 80% at 100% 50%, rgba(255,255,255,0.06) 0%, transparent 60%);
    }
    .cta-banner > * { position: relative; z-index: 1; }
    .cta-banner h2 {
      font-size: clamp(30px, 4vw, 46px);
      font-weight: 900;
      color: white;
      margin-bottom: 16px;
    }
    .cta-banner p {
      font-size: 18px; color: rgba(255,255,255,0.8); margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;
    }
    .cta-banner .btn-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

    /* ── CONTACT ────────────────────────────────────── */
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
    }
    .contact-info h3 { font-size: 24px; font-weight: 800; color: var(--navy); margin-bottom: 16px; }
    .contact-info p { font-size: 16px; color: var(--grey-600); line-height: 1.75; margin-bottom: 32px; }
    .contact-detail {
      display: flex; align-items: center; gap: 14px; margin-bottom: 16px;
    }
    .contact-detail-icon {
      width: 44px; height: 44px;
      background: var(--off-white);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    .contact-detail-text { font-size: 15px; color: var(--text); font-weight: 500; }
    .contact-detail-text a { color: var(--azure); text-decoration: none; }
    .contact-detail-text a:hover { text-decoration: underline; }

    .contact-form {
      background: var(--off-white);
      border-radius: 16px;
      padding: 40px;
    }
    .form-group { margin-bottom: 20px; }
    .form-group label {
      display: block; font-size: 13px; font-weight: 600; color: var(--text);
      margin-bottom: 6px; letter-spacing: 0.02em;
    }
    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 12px 16px;
      border: 1.5px solid var(--grey-100);
      border-radius: 8px;
      font-size: 15px;
      font-family: 'Inter', sans-serif;
      color: var(--text);
      background: white;
      transition: border-color var(--transition);
      outline: none;
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      border-color: var(--azure);
      box-shadow: 0 0 0 3px rgba(0,120,212,0.1);
    }
    .form-group textarea { min-height: 130px; resize: vertical; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    /* ── FOOTER ─────────────────────────────────────── */
    .footer {
      background: var(--navy);
      color: var(--white);
      padding: 64px 0 32px;
    }
    .footer__grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 48px;
      margin-bottom: 48px;
    }
    .footer__brand p {
      font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.75; margin-top: 16px;
    }
    .footer__col h4 {
      font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
      color: rgba(255,255,255,0.4); margin-bottom: 18px;
    }
    .footer__col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer__col ul a {
      font-size: 14px; color: rgba(255,255,255,0.65); text-decoration: none;
      transition: color var(--transition);
    }
    .footer__col ul a:hover { color: var(--white); }
    .footer__bottom {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }
    .footer__bottom p { font-size: 13px; color: rgba(255,255,255,0.4); }
    .footer__bottom-right { display: flex; gap: 20px; }
    .footer__bottom-right a { font-size: 13px; color: rgba(255,255,255,0.4); text-decoration: none; }
    .footer__bottom-right a:hover { color: rgba(255,255,255,0.7); }

    /* Microsoft badge */
    .ms-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 18px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.6);
      margin-top: 20px;
    }
    .ms-badge-icon { font-size: 18px; }

    /* ── MOBILE ─────────────────────────────────────── */
    .hamburger { display: none; cursor: pointer; background: none; border: none; padding: 8px; }
    .hamburger span { display: block; width: 22px; height: 2px; background: white; margin: 4px 0; border-radius: 2px; }

    @media (max-width: 1024px) {
      .hero__content { grid-template-columns: 1fr; gap: 48px; }
      .hero__right { justify-content: flex-start; }
      .hero__card { max-width: 100%; }
      .why-grid { grid-template-columns: 1fr; gap: 48px; }
      .about-grid { grid-template-columns: 1fr; gap: 48px; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); }
      .stat-item:nth-child(even) { border-bottom: none; }
      .approach-grid { grid-template-columns: repeat(2, 1fr); }
      .approach-step:nth-child(2) { border-right: none; }
      .approach-step { border-bottom: 1px solid var(--grey-100); }
      .approach-step:nth-child(3), .approach-step:nth-child(4) { border-bottom: none; }
      .contact-grid { grid-template-columns: 1fr; gap: 48px; }
      .footer__grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
      .section { padding: 64px 0; }
      .navbar__nav { display: none; }
      .navbar__cta .btn-outline { display: none; }
      .hamburger { display: block; }
      .hero__content { padding: 48px 0; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .approach-grid { grid-template-columns: 1fr; }
      .approach-step { border-right: none; border-bottom: 1px solid var(--grey-100); }
      .footer__grid { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>

