<!-- ── WHY CHOOSE ── -->
<section class="section section--grey" id="approach">
  <div class="container">
    <div class="why-grid">
      <div class="why-image">
        <div class="why-feature">
          <div class="why-feature-icon">🎯</div>
          <div class="why-feature-text">
            <h4>Senior-led from start to finish</h4>
            <p>Your engagement is always led by a senior architect — ensuring continuity, accountability, and the right decisions at every stage.</p>
          </div>
        </div>
        <div class="why-feature">
          <div class="why-feature-icon">🔒</div>
          <div class="why-feature-text">
            <h4>Security-first by default</h4>
            <p>Every design embeds security and compliance from the ground up.</p>
          </div>
        </div>
        <div class="why-feature">
          <div class="why-feature-icon">📊</div>
          <div class="why-feature-text">
